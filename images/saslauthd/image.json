{
  "name": "saslauthd",
  "type": "build",
  "basePreference": "alpine",
  "platforms": ["linux/amd64", "linux/arm64"],
  "context": "images/saslauthd",
  "dockerfile": "Dockerfile",
  "image": "ghcr.io/joejulian/container-images/saslauthd",
  "versionCommand": "apk info -vv 2>/dev/null | sed -n 's/^cyrus-sasl-//p' | sed -n '1s/ - .*//p' | sed -n '1s/-r/-/p'"
}
