  "image": "ghcr.io/joejulian/container-images/cyrus-imap",
  "versionCommand": "cyr_buildinfo 2>/dev/null | sed -n 's/.*\\\"CYRUS_VERSION\\\": \\\"\\([^\\\"]*\\)\\\".*/\\1/p'"
}

